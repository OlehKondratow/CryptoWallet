#!/bin/bash
# Environment variables for infrastructure setup

# Gitea database configuration
export DB_TYPE=sqlite3
export DB_PATH=/data/gitea/gitea.db

# Gitea security & access
export GITEA_INSTANCE_URL=http://localhost:3000
export GITEA_ROOT_URL=http://localhost:3000/
export GITEA_DISABLE_REGISTRATION=false
export GITEA_REQUIRE_SIGNIN=false

# Act Runner configuration
export RUNNER_NAME=crypto-wallet-hil-runner
export RUNNER_LABELS=linux/amd64,crypto,hil,stm32
export RUNNER_CAPACITY=1

# Runner registration (set after creating token in Gitea admin)
export GITEA_RUNNER_TOKEN=7oZyCgKu7HzF8dtWSwJcdl4nTfhX0SGsWGpnHkpe

# Docker configuration
export DOCKER_BUILDKIT=1
export COMPOSE_PROJECT_NAME=cryptowallet

# Hardware access (adjust based on your setup)
export STM32_SERIAL_PORT=/dev/ttyACM0
export STM32_BAUD_RATE=115200
export OPENOCD_INTERFACE=interface/stlink-v2-1.cfg
export OPENOCD_TARGET=target/stm32h7x.cfg

# Optional: PostgreSQL (if using instead of SQLite)
# export DB_TYPE=postgres
# export DB_HOST=postgres
# export DB_PORT=5432
# export DB_NAME=gitea
# export DB_USER=gitea
# export POSTGRES_PASSWORD=your_secure_password_here

# Build options
export ARM_GCC_FLAGS=-mcpu=cortex-m7\ -mfloat-abi=hard\ -mfpu=fpv5-d16
export OPTIMIZATION_LEVEL=-O2

# Testing
export TEST_TIMEOUT=3600
export RNG_CAPTURE_SIZE_MB=2
export DIEHARDER_SAMPLES=1000000

# Скопируйте в infra/.env и подстройте (podman compose подхватывает .env из каталога infra).
# Секреты (токены runner) держите в .env.local (gitignore).

# --- Gitea публичный URL (должен совпадать с тем, как открываете в браузере) ---
# По умолчанию — loopback (без shim):
GITEA_ROOT_URL=http://127.0.0.1:3000/
GITEA_SERVER_DOMAIN=127.0.0.1

# Доступ с хоста по http://192.168.127.5:3000/ — сначала: sudo ./infra/macvlan-host-shim.sh add
# затем замените на:
# GITEA_ROOT_URL=http://192.168.127.5:3000/
# GITEA_SERVER_DOMAIN=192.168.127.5

COMPOSE_PROJECT_NAME=cryptowallet
